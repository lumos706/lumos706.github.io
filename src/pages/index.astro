---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArrowIcon from '@/components/ArrowIcon.astro';
import HeroVisual from '@/components/HeroVisual.astro';
import PostRow from '@/components/PostRow.astro';
import { formatDate, sortPosts } from '@/lib/blog';

const posts = sortPosts(await getCollection('blog', ({ data }) => !data.draft));
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const latest = posts.filter((post) => post.id !== featured.id).slice(0, 3);
---

<BaseLayout>
  <section class="wrap hero">
    <div class="hero-copy" data-reveal>
      <h1>在代码与生活之间，留下一束光。</h1>
      <p>这里记录技术实践、设计观察，也收藏那些让日常变得清晰的微小发现。慢一点写，诚实一点想。</p>
      <div class="hero-actions">
        <a class="button-primary" href="#featured">开始阅读 <ArrowIcon /></a>
        <a class="hero-secondary" href="/about/">关于这个博客</a>
      </div>
    </div>
    <div class="hero-visual" data-reveal><HeroVisual /></div>
  </section>

  {featured && (
    <section id="featured" class="section featured-section">
      <div class="wrap">
        <div class="section-head"><h2 class="section-title">精选文章</h2><span class="section-index">FEATURED / 01</span></div>
        <div class="featured">
          <div class="feature-poster" data-reveal>
            <span class="poster-label">LUMOS FIELD NOTE</span>
            <span class="poster-number">01</span>
            <p class="poster-note">Independent publishing, deliberate design, and a small corner of the open web.</p>
          </div>
          <div class="feature-copy" data-reveal>
            <div class="meta-label">{featured.data.category} · {featured.data.readingTime} 分钟阅读 · {formatDate(featured.data.pubDate)}</div>
            <h3>{featured.data.title}</h3>
            <p>{featured.data.description}</p>
            <a class="text-link" href={`/posts/${featured.id}/`}>阅读全文 <ArrowIcon /></a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="wrap latest-section">
    <div class="section-head"><h2 class="section-title">最近更新</h2><span class="section-index">THE LATEST / {String(latest.length).padStart(2, '0')}</span></div>
    <div>
      {latest.map((post, index) => <PostRow index={index + 1} slug={post.id} title={post.data.title} category={post.data.category} pubDate={post.data.pubDate} />)}
    </div>
    <a class="all-posts text-link" href="/posts/">查看全部文章 <ArrowIcon direction="right" /></a>
  </section>

  <section class="topics-section">
    <div class="wrap">
      <h2 class="topics-title" data-reveal>CODE <em>/</em> DESIGN <em>/</em> LIFE</h2>
      <div class="topic-grid">
        <div data-reveal><strong>代码</strong><p>记录开发实践、工具选择，以及那些值得被反复使用的解决方案。</p></div>
        <div data-reveal><strong>设计</strong><p>观察产品、界面和文字如何共同构成一种清晰而克制的体验。</p></div>
        <div data-reveal><strong>生活</strong><p>在效率之外，保存阅读、散步与日常里偶然亮起的时刻。</p></div>
      </div>
    </div>
  </section>

  <section class="wrap about-strip">
    <h2 data-reveal>一间持续生长的<br />数字书房。</h2>
    <div class="about-copy" data-reveal>
      <p>Lumos 是一个独立个人博客。这里没有信息流的催促，也不追逐转瞬即逝的热点；只有经过整理的经验、仍在发生的思考，以及对开放互联网的一点坚持。</p>
      <a class="text-link" href="/about/">更多关于我 <ArrowIcon /></a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    min-height: 730px;
    grid-template-columns: 1.06fr 0.94fr;
    gap: clamp(48px, 6.5625vw, 84px);
    align-items: center;
    padding-block: 72px 88px;
  }

  .hero h1 {
    max-width: 700px;
    margin: 0 0 32px;
    font: 500 clamp(4rem, 6vw, 5.75rem) / 1.02 var(--serif);
    letter-spacing: -0.055em;
  }

  .hero-copy > p {
    max-width: 550px;
    margin: 0;
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.9;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 30px;
    margin-top: 44px;
  }

  .hero-secondary {
    padding-block: 8px;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.88rem;
    transition: color 180ms ease, border-color 180ms ease;
  }

  .hero-secondary:hover { color: var(--ink); border-color: var(--ink); }

  .featured {
    display: grid;
    grid-template-columns: 1.12fr 0.88fr;
    gap: clamp(50px, 6vw, 82px);
    align-items: center;
  }

  .feature-poster {
    position: relative;
    min-height: 475px;
    padding: 36px;
    overflow: hidden;
    color: #171714;
    background: #ddff57;
    isolation: isolate;
  }

  .feature-poster::before {
    position: absolute;
    right: -135px;
    bottom: -165px;
    width: 450px;
    height: 450px;
    border: 88px solid #171714;
    border-radius: 50%;
    content: '';
    z-index: 0;
    opacity: 0.22;
  }

  .feature-poster::after {
    position: absolute;
    top: 118px;
    left: 36px;
    width: calc(100% - 72px);
    height: 1px;
    content: '';
    background: rgba(23, 23, 20, 0.35);
    z-index: 0;
  }

  .poster-label { position: relative; z-index: 2; font-size: 0.68rem; letter-spacing: 0.16em; }
  .poster-number { position: absolute; z-index: 2; bottom: -36px; left: 28px; font: 500 13.1rem / 1 var(--serif); letter-spacing: -0.08em; }
  .poster-note { position: absolute; z-index: 2; top: 150px; right: 34px; width: 135px; margin: 0; font-size: 0.68rem; line-height: 1.7; }
  .feature-copy h3 { margin: 22px 0 24px; font: 500 clamp(2.5rem, 4vw, 3.1rem) / 1.17 var(--serif); letter-spacing: -0.04em; }
  .feature-copy p { margin: 0; color: var(--muted); font-size: 1rem; line-height: 1.9; }
  .feature-copy .text-link { margin-top: 24px; }

  .latest-section { padding-block: clamp(94px, 9vw, 136px); }
  .all-posts { margin-top: 42px; }

  .topics-section {
    padding-block: clamp(90px, 8vw, 116px);
    color: #f5f2e9;
    background: #171714;
  }

  .topics-title {
    margin: 0;
    font: 500 clamp(4.25rem, 9.1vw, 8.25rem) / 0.92 var(--serif);
    letter-spacing: -0.065em;
    white-space: nowrap;
  }

  .topics-title em { color: #ddff57; font-style: normal; }
  .topic-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(38px, 5vw, 72px); margin-top: 88px; padding-top: 32px; border-top: 1px solid rgba(245, 242, 233, 0.2); }
  .topic-grid strong { display: block; margin-bottom: 16px; font: 500 1.55rem / 1 var(--serif); }
  .topic-grid p { margin: 0; color: rgba(245, 242, 233, 0.58); font-size: 0.88rem; line-height: 1.8; }

  .about-strip { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(60px, 9vw, 120px); align-items: start; padding-block: clamp(96px, 10vw, 132px); }
  .about-strip h2 { margin: 0; font: 500 clamp(3rem, 4.8vw, 3.6rem) / 1.08 var(--serif); letter-spacing: -0.045em; }
  .about-copy p { margin: 0 0 30px; color: var(--muted); font-size: 1rem; line-height: 1.95; }

  @media (max-width: 860px) {
    .hero { grid-template-columns: 1fr; min-height: auto; gap: 54px; padding-block: 60px 72px; }
    .hero h1 { font-size: clamp(3.5rem, 12vw, 5.2rem); }
    .hero-visual { width: min(100%, 620px); }
    .featured { grid-template-columns: 1fr; }
    .feature-poster { min-height: 430px; }
  }

  @media (max-width: 700px) {
    .hero h1 { font-size: clamp(3.2rem, 14vw, 4.3rem); }
    .hero-copy > p { font-size: 0.96rem; }
    .hero-actions { align-items: flex-start; flex-direction: column; gap: 16px; }
    .button-primary { width: 100%; }
    .topics-title { font-size: clamp(3.65rem, 17vw, 5.5rem); white-space: normal; }
    .topic-grid { grid-template-columns: 1fr; gap: 38px; margin-top: 62px; }
    .about-strip { grid-template-columns: 1fr; gap: 46px; }
  }
</style>
