---
import ArrowIcon from './ArrowIcon.astro';

interface Props {
  index: number;
  slug: string;
  title: string;
  category: string;
  pubDate: Date;
}

const { index, slug, title, category, pubDate } = Astro.props;
const date = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(pubDate).replaceAll('/', '.');
---

<a class="post-row" href={`/posts/${slug}/`} data-reveal>
  <span class="post-index">{String(index).padStart(2, '0')}</span>
  <span class="post-meta">{category}<br />{date}</span>
  <span class="post-title">{title}</span>
  <ArrowIcon />
</a>

<style>
  .post-row {
    display: grid;
    grid-template-columns: 74px 190px minmax(0, 1fr) 40px;
    gap: 24px;
    align-items: center;
    min-height: 138px;
    padding-inline: 0;
    border-top: 1px solid var(--line);
    transition: color 260ms ease, background-color 260ms ease, padding 300ms var(--ease);
  }

  .post-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .post-row:hover,
  .post-row:focus-visible {
    padding-inline: 22px;
    color: #171714;
    background: var(--light);
  }

  .post-row:hover :global(.arrow-icon),
  .post-row:focus-visible :global(.arrow-icon) {
    transform: translate(3px, -3px);
  }

  .post-index {
    color: var(--muted);
    font: 400 1.05rem / 1 var(--serif);
  }

  .post-row:hover .post-index,
  .post-row:focus-visible .post-index,
  .post-row:hover .post-meta,
  .post-row:focus-visible .post-meta {
    color: rgba(23, 23, 20, 0.66);
  }

  .post-meta {
    color: var(--muted);
    font-size: 0.72rem;
    line-height: 1.8;
  }

  .post-title {
    font: 500 clamp(1.4rem, 2.2vw, 1.85rem) / 1.28 var(--serif);
    letter-spacing: -0.025em;
  }

  @media (max-width: 700px) {
    .post-row {
      grid-template-columns: 36px minmax(0, 1fr) 26px;
      gap: 12px;
      min-height: auto;
      padding-block: 28px;
    }

    .post-meta { grid-column: 2; grid-row: 1; }
    .post-title { grid-column: 2; grid-row: 2; font-size: 1.35rem; }
    .post-row :global(.arrow-icon) { grid-column: 3; grid-row: 1 / 3; }
    .post-row:hover, .post-row:focus-visible { padding-inline: 12px; }
  }
</style>
