---
import Brand from './Brand.astro';
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <div class="footer-top">
      <a href="/" aria-label="Lumos 首页"><Brand light /></a>
      <nav class="footer-links" aria-label="页脚导航">
        <a href="https://github.com/lumos706" target="_blank" rel="noreferrer">GitHub</a>
        <a href="/rss.xml">RSS</a>
        <a href="/archive/">文章归档</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} LUMOS</span>
      <span>DESIGNED FOR THE OPEN WEB</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    color: #f5f2e9;
    background: #171714;
  }

  .footer-inner {
    display: flex;
    min-height: 246px;
    flex-direction: column;
    justify-content: space-between;
    padding-block: 58px 36px;
  }

  .footer-top,
  .footer-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
  }

  .footer-links {
    display: flex;
    gap: 30px;
    color: rgba(245, 242, 233, 0.62);
    font-size: 0.8rem;
  }

  .footer-links a {
    transition: color 180ms ease;
  }

  .footer-links a:hover {
    color: var(--light);
  }

  .footer-bottom {
    color: rgba(245, 242, 233, 0.42);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }

  @media (max-width: 620px) {
    .footer-inner { min-height: 300px; }
    .footer-top { align-items: flex-start; flex-direction: column; }
    .footer-links { flex-wrap: wrap; }
    .footer-bottom { align-items: flex-start; flex-direction: column; gap: 8px; }
  }
</style>
