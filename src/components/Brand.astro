---
interface Props {
  light?: boolean;
}

const { light = false } = Astro.props;
---

<span class:list={['brand-lockup', { light }]}>
  <span class="brand-mark" aria-hidden="true"></span>
  <span>LUMOS</span>
</span>

<style>
  .brand-lockup {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font: 800 1.2rem / 1 var(--sans);
    letter-spacing: 0.12em;
  }

  .brand-lockup.light {
    color: #f5f2e9;
  }

  .brand-mark {
    position: relative;
    width: 22px;
    height: 22px;
    border: 2px solid currentColor;
    border-radius: 50%;
  }

  .brand-mark::before,
  .brand-mark::after {
    position: absolute;
    top: 50%;
    left: 50%;
    content: '';
    background: currentColor;
    transform: translate(-50%, -50%);
  }

  .brand-mark::before {
    width: 30px;
    height: 2px;
  }

  .brand-mark::after {
    width: 2px;
    height: 30px;
  }
</style>
